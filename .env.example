# ProperChat runs with zero configuration: `npm install && npm run dev` works
# out of the box, and users can paste their own provider keys in the in-app
# Settings panel. Everything below is OPTIONAL and only needed if you want the
# server itself to hold default keys. Do NOT commit real keys; provide them via
# your shell (export ...) or your host's secret store.

# Default interpret backend credential used by the chat proxy when no key is
# supplied in Settings. Must be an `iai_`-prefixed InterpretAI API key.
INTERPRETAI_API_KEY=
# Base URL for the interpret backend. Optional; defaults to staging when unset.
INTERPRET_API_BASE=https://staging.interpretai.tech

# Optional server-side fallbacks for the direct providers. Client-supplied keys
# (Settings) always take precedence. For a public multi-user deploy, prefer
# leaving these unset so each user brings their own.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional: presign media uploads to the backend object store. When unset,
# attachments fall back to inline data URLs and uploads are disabled.
NEXT_PUBLIC_IAI_STORE=
